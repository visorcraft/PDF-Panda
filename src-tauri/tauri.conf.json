{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf-editor",
  "version": "0.1.1",
  "identifier": "com.pdf-editor.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PDF Editor MVP",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "vendor/pdfium/libpdfium.so": "vendor/pdfium/libpdfium.so"
    },
    "icon": [
      "icons/32x32.png",
      "icons/96x96.png",
      "icons/128x128.png",
      "icons/144x144.png",
      "icons/192x192.png",
      "icons/512x512.png"
    ]
  }
}
