{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Panda",
  "version": "1.1.4",
  "identifier": "com.pdf-panda.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PDF Panda",
        "width": 950,
        "height": 750,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/visorcraft/PDF-Panda/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVEOTQyQzZBNkMxN0Q0MTQKUldRVTFCZHNhaXlVWFNSZFlQM3VxOXptalpzN3ZwQzJjUXRaRWVwOWtaTHBPR21hVncyd0JtcGUK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "mimeType": "application/pdf",
        "role": "Editor"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "pdf-panda.desktop"
      },
      "rpm": {
        "desktopTemplate": "pdf-panda.desktop"
      }
    }
  }
}
