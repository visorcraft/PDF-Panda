{
  "root": true,
  "env": { "browser": true, "es2024": true },
  "extends": ["eslint:recommended"],
  "parserOptions": { "ecmaVersion": 2024, "sourceType": "module" },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  },
  "ignorePatterns": ["dist/", "src-tauri/target/", "node_modules/"]
}
